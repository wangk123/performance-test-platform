{
  "uid": "jmx-jvm",
  "title": "JMX Exporter JVM",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "project_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_bytes_used, project_id)",
        "refresh": 1
      },
      {
        "name": "target_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_bytes_used{project_id=\"$project_id\"}, target_id)",
        "refresh": 1,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_bytes_used{area=\"heap\",project_id=\"$project_id\",target_id=~\"$target_id\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GC Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(jvm_gc_collection_seconds_sum{project_id=\"$project_id\",target_id=~\"$target_id\"}[1m])"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_current{project_id=\"$project_id\",target_id=~\"$target_id\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Class Loading",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_classes_loaded{project_id=\"$project_id\",target_id=~\"$target_id\"}"
        }
      ]
    }
  ]
}
